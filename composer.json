{
    "name": "calcasa/api",
    "version": "1.6.0-beta4",
    "description": "The Calcasa API is used to connect to Calcasa provided services. For more information, please visit [Documentation](https://docs.calcasa.nl) or [GitHub](https://github.com/calcasa/api).",
    "keywords": [
        "openapitools",
        "openapi-generator",
        "openapi",
        "php",
        "sdk",
        "rest",
        "api"
    ],
    "homepage": "https://github.com/calcasa/api-php",
    "license": "Apache-2.0",
    "authors": [
        {
            "name": "Calcasa",
            "homepage": "https://calcasa.nl"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "guzzlehttp/guzzle": "^7.3",
        "guzzlehttp/psr7": "^1.7 || ^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^8.0 || ^9.0",
        "friendsofphp/php-cs-fixer": "^3.5"
    },
    "autoload": {
        "psr-4": { "Calcasa\\Api\\" : "lib/" }
    },
    "autoload-dev": {
        "psr-4": { "Calcasa\\Api\\Test\\" : "test/" }
    }
}
